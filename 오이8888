local function connectTorsos()
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local torso = char:FindFirstChild("Torso")
    if not hrp or not torso then return end
    if torsoWeld and torsoWeld.Parent then torsoWeld:Destroy() end
    torsoWeld = Instance.new("WeldConstraint")
    torsoWeld.Part0 = hrp
    torsoWeld.Part1 = torso
    torsoWeld.Parent = hrp
end

local function fixAllLimbs()
    local char = LocalPlayer.Character
    if not char then return end
    local torso = char:FindFirstChild("Torso")
    if not torso then return end
    local limbs = {"Left Arm", "Right Arm", "Left Leg", "Right Leg", "Head"}
    for _, limbName do
        local limb = char:FindFirstChild(limbName)
        if limb then
            if not limbWelds[limbName] or not limbWelds[limbName].Parent then
                local weld = Instance.new("WeldConstraint")
                weld.Part0 = limb
                weld.Part1 = torso
                weld.Parent = limb
                limbWelds[limbName] = weld
            end
        end
    end
end

local function forceKeepBody()
    if not weldKeepAlive then return end
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local torso = char:FindFirstChild("Torso")
    if hrp and torso then
        if not torsoWeld or not torsoWeld.Parent or torsoWeld.Part0 ~= hrp or torsoWeld.Part1 ~= torso then
            connectTorsos()
        end
    end
    fixAllLimbs()
end

task.spawn(function()
    while true do
