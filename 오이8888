-- Anti Release (Death Proof)
local AntiReleaseT = false
local antiReleaseThread = nil
local antiReleaseSpawnThread = nil

local function startAntiRelease()
    antiReleaseSpawnThread = task.spawn(function()
        while AntiReleaseT do
            local character = LocalPlayer.Character
            local rootPart = character and character:FindFirstChild("HumanoidRootPart")
            local spawnedToysFolder = Workspace:FindFirstChild(LocalPlayer.Name .. "SpawnedInToys")
            
            if rootPart and spawnedToysFolder then
                if not spawnedToysFolder:FindFirstChild("FoodHamburger") then
                    local spawnArgs = { "FoodHamburger", rootPart.CFrame * CFrame.new(-3.53, 0, 3.53), Vector3.new(0, 140, 0) }
                    pcall(function()
                        rs:WaitForChild("MenuToys"):WaitForChild("SpawnToyRemoteFunction"):InvokeServer(unpack(spawnArgs))
                    end)
                end
            end
            task.wait(0.3)
        end
    end)
    
    antiReleaseThread = task.spawn(function()
        while AntiReleaseT do
            local character = LocalPlayer.Character
            local rootPart = character and character:FindFirstChild("HumanoidRootPart")
            local spawnedToysFolder = Workspace:FindFirstChild(LocalPlayer.Name .. "SpawnedInToys")
            
            if character and rootPart and spawnedToysFolder then
                local currentItem = spawnedToysFolder:FindFirstChild("FoodHamburger")
                local holdPart = currentItem and currentItem:FindFirstChild("HoldPart")
                if holdPart then
                    local holdRemote = holdPart:FindFirstChild("HoldItemRemoteFunction")
                    local dropRemote = holdPart:FindFirstChild("DropItemRemoteFunction")
                    if holdRemote and dropRemote then
                        pcall(function() holdRemote:InvokeServer(currentItem, character) end)
                        task.wait(0.5)
                        if not AntiReleaseT then break end
                        pcall(function()
                            dropRemote:InvokeServer(currentItem, CFrame.new(rootPart.Position.X, 99999, rootPart.Position.Z), Vector3.zero)
                        end)
                    end
                end
            end
            task.wait(0.1)
        end
    end)
end

local function stopAntiRelease()
    AntiReleaseT = false
    if antiReleaseSpawnThread then task.cancel(antiReleaseSpawnThread) end
    if antiReleaseThread then task.cancel(antiReleaseThread) end
    pcall(function()
        local folder = Workspace:FindFirstChild(LocalPlayer.Name .. "SpawnedInToys")
        local item = folder and folder:FindFirstChild("FoodHamburger")
        if item then rs:WaitForChild("MenuToys"):WaitForChild("DestroyToy"):FireServer(item) end
    end)
end

