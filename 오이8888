-- Anti Vehicle Toy
getgenv().AntiVehicleToyEnabled = false
local AntiVehicleToyThread = nil
local Whitelist = {}
local WhiteListMode = false

local function startAntiVehicleToy()
    if AntiVehicleToyThread then task.cancel(AntiVehicleToyThread) end
    if not getgenv().AntiVehicleToyEnabled then return end
    
    AntiVehicleToyThread = task.spawn(function()
        local FallenY = Workspace.FallenPartsDestroyHeight
        local targetY = (FallenY <= -50000 and -49999) or (FallenY <= -100 and -99) or -100
        local dropPos = CFrame.new(0, targetY, 9999)
        local targetItems = {"CreatureBlobman", "TractorRed", "TractorOrange", "TractorGreen", "SantaSleigh"}
        local processedBlobs = {}
        
        while getgenv().AntiVehicleToyEnabled do
            task.wait(0.1)
            local char = LocalPlayer.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            if not root or not hum then continue end
            
            local allItems = {}
            for _, p in ipairs(Players:GetPlayers()) do
                if p == LocalPlayer then continue end
                if WhiteListMode and table.find(Whitelist, p.Name) then continue end
                local folder = Workspace:FindFirstChild(p.Name .. "SpawnedInToys")
                if folder then
                    for _, item in ipairs(folder:GetChildren()) do
                        if item:IsA("Model") and table.find(targetItems, item.Name) then
                            local vs = item:FindFirstChildOfClass("VehicleSeat")
                            if vs and (not vs.Occupant or vs.Occupant == hum) then
                                if not processedBlobs[tostring(item:GetDebugId())] then table.insert(allItems, item) end
                            end
                        end
                    end
                end
            end
            
            for _, item in ipairs(allItems) do
                local vs = item:FindFirstChildOfClass("VehicleSeat")
                if vs then
                    root.Anchored = true; vs:Sit(hum)
                    task.wait(0.1)
                    hum:ChangeState(Enum.HumanoidStateType.Running)
                    task.wait()
                    if item.PrimaryPart then item:SetPrimaryPartCFrame(dropPos) end
                    root.Anchored = false
                    processedBlobs[tostring(item:GetDebugId())] = true
                end
                break
            end
        end
    end)
end

AntiTab:CreateToggle({
    Name = "Anti Vehicle Toy",
    CurrentValue = false,
    Callback = function(Value)
        getgenv().AntiVehicleToyEnabled = Value
        if Value then startAntiVehicleToy() else if AntiVehicleToyThread then task.cancel(AntiVehicleToyThread) end end
    end
})

