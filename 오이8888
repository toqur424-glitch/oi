        task.wait(0.001)
    end
end)

local function startMoving()
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    if movementBV then movementBV:Destroy() end
    if movementBG then movementBG:Destroy() end
    movementBV = Instance.new("BodyVelocity")
    movementBV.Name = "AntiGrabMove"
    movementBV.MaxForce = Vector3.new(1e6, 1e6, 1e6)
    movementBV.Velocity = Vector3.zero
    movementBV.Parent = hrp
    movementBG = Instance.new("BodyGyro")
    movementBG.Name = "AntiGrabGyro"
    movementBG.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
    movementBG.Parent = hrp
    isMoving = true
end

local function stopMoving()
    if movementBV then movementBV:Destroy() end
    if movementBG then movementBG:Destroy() end
    movementBV = nil
    movementBG = nil
    isMoving = false
end

local function updateMovement()
    if not isMoving then return end
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp or not movementBV or not movementBG then return end
    local moveDir = Vector3.zero
    local speed = 20
    if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + camera.CFrame.LookVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - camera.CFrame.LookVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - camera.CFrame.RightVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + camera.CFrame.RightVector end
    movementBV.Velocity = moveDir.Magnitude > 0 and moveDir.Unit * speed or Vector3.zero
    movementBG.CFrame = camera.CFrame
end

