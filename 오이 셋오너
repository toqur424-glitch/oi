-- 헬퍼 함수들
local function UpdateCurrentBlobman()
    local char = plr.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    for _, blobs in Workspace:GetDescendants() do
        if blobs.Name == "CreatureBlobman" then
            local seat = blobs:FindFirstChild("VehicleSeat")
            if seat then
                local weld = seat:FindFirstChild("SeatWeld")
                if weld and weld.Part1 == hrp then
                    currentBlobS = blobs
                    break
                end
            end
        end
    end
end

local function BlobGrab(blob, target, side)
    if not blob or not target then return end
    local detector = blob:FindFirstChild(side.."Detector")
    if not detector then return end
    local weld = detector:FindFirstChild(side.."Weld")
    if not weld then return end
    local script = blob:FindFirstChild("BlobmanSeatAndOwnerScript")
    if script and script:FindFirstChild("CreatureGrab") then
        pcall(function() script.CreatureGrab:FireServer(detector, target, weld) end)
    end
end

local function BlobRelease(blob, target, side)
    if not blob or not target then return end
    local detector = blob:FindFirstChild(side.."Detector")
    if not detector then return end
    local weld = detector:FindFirstChild(side.."Weld")
    if not weld then return end
    local script = blob:FindFirstChild("BlobmanSeatAndOwnerScript")
    if script and script:FindFirstChild("CreatureRelease") then
        pcall(function() script.CreatureRelease:FireServer(weld, target) end)
    end
end

local function TP(target)
    local now = tick()
    if now - lastTPTime < TP_COOLDOWN then return false end
    local TCHAR = target.Character
    if not TCHAR then return false end
    local THRP = TCHAR:FindFirstChild("Torso") or TCHAR:FindFirstChild("HumanoidRootPart")
    if not THRP then return false end
    local localChar = plr.Character
    local localHRP = localChar and localChar:FindFirstChild("HumanoidRootPart")
    if not localHRP then return false end
    local ping = plr:GetNetworkPing()
    local offset = THRP.Position + (THRP.Velocity * (ping + 0.15))
    localHRP.CFrame = CFrame.new(offset) * THRP.CFrame.Rotation
    lastTPTime = now
    return true
end

local function UnOwner(target)
    local head = target.Character:FindFirstChild("HumanoidRootPart")
    if head and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
        rs.GrabEvents.DestroyGrabLine:FireServer(head, head.CFrame)
        return true
    end
    return false
end

local function BACK(originCF)
    if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
        plr.Character.HumanoidRootPart.CFrame = originCF
        plr.Character.HumanoidRootPart.AssemblyLinearVelocity = Vector3.zero
        plr.Character.HumanoidRootPart.AssemblyAngularVelocity = Vector3.zero
    end
end

local function safeGetCharacterParts(player)
    if not player then return nil end
    local char = player.Character
    if not char then return nil end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local head = char:FindFirstChild("Head")
    return char, hrp, head
end

local ownerKickInitialized = false

function loopPlayerBlobF4()
    UpdateCurrentBlobman()
    local runningTasks = {}
    local monitoredPlayers = {}
    local independentHoldConnections = {}
    local anchorToggleTasks = {}
    local ownerTags = {}
    local originPositions = {}
    local bodyPositions = {}

    local function cleanupBodyPosition(player)
        if bodyPositions[player] and bodyPositions[player].Parent then
            bodyPositions[player]:Destroy()
        end
        bodyPositions[player] = nil
    end

    local function processPlayer(player)
        if not player then return end
        while blobLoopT4 do
            if not player.Parent then
                cleanupBodyPosition(player)
                return
            end
            local character = player.Character
            while blobLoopT4 and (not character or not character:FindFirstChild("Humanoid")) do
                if not player.Parent then return end
                task.wait(0.001)
                character = player.Character
            end
            local charHUM = character and character:FindFirstChild("Humanoid")
            if not charHUM then task.wait(0.001) continue end
            
            local _, safeHRP, head = safeGetCharacterParts(player)
            if not safeHRP or not head then task.wait(0.001) continue end
            
            local myChar = plr.Character
            local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
            if not myHRP then task.wait(0.001) continue end
            
            local myOriginalCF = myHRP.CFrame
            local charHRP = character:FindFirstChild("HumanoidRootPart")
            local charTOR = character:FindFirstChild("Torso")
            
            if not ownerKickInitialized then
                if charHUM and myHRP and charHRP then
                    for i = 1, 30 do 
                        rs.GrabEvents.SetNetworkOwner:FireServer(charHRP, CFrame.lookAt(myHRP.Position, charHRP.Position))
                    end
                    task.wait(0.001)
                end
                ownerKickInitialized = true
            end
            
            local distance = (myHRP.Position - charHRP.Position).Magnitude
            if distance > 40 then TP(player) task.wait(0.001) end
            
            local tpRunning = true
            task.spawn(function()
                while tpRunning and blobLoopT4 do
                    if not player.Parent then break end
                    TP(player)
                    task.wait(0.001)
                end
            end)
            
            local shouldContinue = false
            while blobLoopT4 do
                if not character.Parent or not charHUM or charHUM.Health <= 0 then 
                    tpRunning = false
                    shouldContinue = true
                    break
                end
                local mySeat = plr.Character and plr.Character:FindFirstChildOfClass("Humanoid") and plr.Character:FindFirstChildOfClass("Humanoid").SeatPart
                local amIRiding = mySeat and mySeat.Parent and mySeat.Parent.Name == "CreatureBlobman"
                rs.GrabEvents.SetNetworkOwner:FireServer(head, head.CFrame)
                local ownerTag = head:FindFirstChild("PartOwner")
                if ownerTag and ownerTag:IsA("StringValue") and ownerTag.Value == plr.Name then
                    break
                else
                    if amIRiding then
                        BlobGrab(currentBlobS, charHRP, "Right")
                        BlobRelease(currentBlobS, charHRP, "Right")
                    end
                end
                task.wait(0.001)
            end
            
            if not shouldContinue then
                tpRunning = false
                UnOwner(player)
                if myOriginalCF then
                    charHRP.CFrame = myOriginalCF * CFrame.new(0, OLTPValue.Y, 0)
                    task.wait(0.001)
                end
                BACK(myOriginalCF)
                
                cleanupBodyPosition(player)
                
                -- [극대화] 무한 홀딩 BodyPosition
                local bp = Instance.new("BodyPosition")
                bp.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
                bp.P = math.huge
                bp.D = 50
                bp.Parent = charHRP
                bodyPositions[player] = bp
                
                independentHoldConnections[player] = RunService.Heartbeat:Connect(function()
                    if not blobLoopT4 or not character or not character.Parent or not charHRP or not charHUM or charHUM.Health <= 0 then
                        if independentHoldConnections[player] then independentHoldConnections[player]:Disconnect() end
                        cleanupBodyPosition(player)
                        return
                    end
                    
                    -- [극대화] 타겟 완벽 고정
                    charHRP.AssemblyLinearVelocity = Vector3.zero
                    charHRP.AssemblyAngularVelocity = Vector3.zero
                    if charTOR then
                        charTOR.AssemblyLinearVelocity = Vector3.zero
                        charTOR.AssemblyAngularVelocity = Vector3.zero
                    end
                    charHUM.PlatformStand = true
                    
                    local currentDistance = (myHRP.Position - charHRP.Position).Magnitude
                    if currentDistance > 50 then
                        TP(player)
                        if myOriginalCF then charHRP.CFrame = myOriginalCF * CFrame.new(0, OLTPValue.Y, 0) end
                        BACK(myOriginalCF)
                    end
                    
                    -- [극대화] 연사 속도
                    local currentSeat = plr.Character and plr.Character:FindFirstChildOfClass("Humanoid") and plr.Character:FindFirstChildOfClass("Humanoid").SeatPart
                    local isRidingNow = currentSeat and currentSeat.Parent and currentSeat.Parent.Name == "CreatureBlobman"
                    
                    for i = 1, 3 do
                        if not isRidingNow then
                            rs.GrabEvents.SetNetworkOwner:FireServer(charHRP, CFrame.lookAt(myHRP.Position, charHRP.Position)) 
                        else
                            rs.GrabEvents.SetNetworkOwner:FireServer(charHRP, CFrame.lookAt(myHRP.Position, charHRP.Position))
                            rs.GrabEvents.DestroyGrabLine:FireServer(charHRP) 
                        end
                    end
                    
                    if blobLoopT4 and bodyPositions[player] and bodyPositions[player].Parent then
                        bodyPositions[player].Position = myHRP.Position + OLTPValue
                    end
                end)
                
                while blobLoopT4 do
                    if not character.Parent or not charHRP.Parent or charHUM.Health <= 0 then 
                        if independentHoldConnections[player] then independentHoldConnections[player]:Disconnect() end
                        cleanupBodyPosition(player)
                        break 
                    end
                    task.wait(0.001)
                end
                cleanupBodyPosition(player)
            end
            task.wait(0.001)
        end
    end

    task.spawn(function()
        while blobLoopT4 do
            for _, name in ipairs(kickTargetList) do
                local player = game.Players:FindFirstChild(name)
                if not player or player == plr then continue end
                if not monitoredPlayers[player] then
                    monitoredPlayers[player] = true
                    if not runningTasks[player] then
                        runningTasks[player] = task.spawn(function()
                            pcall(function() processPlayer(player) end)
                            runningTasks[player] = nil
                            monitoredPlayers[player] = nil
                        end)
                    end
                end
            end
            task.wait(0.001)
        end
        ownerKickInitialized = false
    end)
end

